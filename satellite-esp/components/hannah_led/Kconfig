menu "Hannah LED"

    config HANNAH_LED_GPIO
        int "SK6812 / WS2812B Data GPIO"
        default 5
        help
            GPIO für den SK6812MINI-E-Ring (RMT-Peripheral).
            PCB Rev.3: GPIO5 → SN74AHCT125 Level-Shifter → LED-Ring.
            DevKitC-1 Breadboard: GPIO48.

    config HANNAH_LED_COUNT
        int "Anzahl LEDs im Ring"
        default 12
        range 1 64

    config HANNAH_STATUS_LED_ENABLED
        bool "Status-LED aktivieren"
        default y
        help
            Einfache GPIO-LED die leuchtet wenn der ESP läuft.

    config HANNAH_STATUS_LED_GPIO
        int "Status-LED GPIO"
        default 18
        depends on HANNAH_STATUS_LED_ENABLED
        help
            PCB Rev.4: GPIO18.

endmenu
