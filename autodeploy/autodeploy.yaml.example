server_url: https://hannah-update.sgessinger.de
token: your-bearer-token-here
poll_interval: 300  # seconds

# Name of this agent's own systemd unit — triggers self-restart after self-update.
self_service: hannah-autodeploy

components:
  - name: autodeploy
    channel: autodeploy-stable
    install_dir: /opt/hannah/autodeploy
    service: hannah-autodeploy
    post_install: "/opt/hannah/venv/bin/pip install -q -r /opt/hannah/autodeploy/requirements.txt"

  - name: core
    channel: core-stable
    install_dir: /opt/hannah/core
    service: hannah-core
    post_install: "/opt/hannah/venv/bin/pip install -q -r /opt/hannah/core/requirements.txt"

  - name: proxy
    channel: proxy-stable
    install_dir: /opt/hannah/proxy
    service: hannah-proxy

  - name: voiceid
    channel: voiceid-stable
    install_dir: /opt/hannah/voiceid
    service: hannah-voiceid  # macOS: use the launchd label instead, e.g. com.hannah.voiceid
    post_install: "/opt/hannah/venv/bin/pip install -q -r /opt/hannah/voiceid/requirements.txt"
