menu "Hannah LED"

    config HANNAH_LED_GPIO
        int "SK6812 / WS2812B Data GPIO"
        default 5
        help
            GPIO für den SK6812MINI-E-Ring (RMT-Peripheral).
            PCB Rev.3: GPIO5 → SN74AHCT125 Level-Shifter → LED-Ring.
            DevKitC-1 Breadboard: GPIO48.

    config HANNAH_LED_COUNT
        int "Anzahl LEDs im Ring"
        default 12
        range 1 64

endmenu
