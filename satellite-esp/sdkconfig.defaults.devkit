# Hannah Satellite — ESP32-S3 DevKitC-1 (Breadboard)
# Mikrofon: INMP441 × 2 (I2S), Speaker: MAX98357A, LED: onboard WS2812B

# Mikrofon — I2S (INMP441)
CONFIG_HANNAH_MIC_TYPE_I2S=y
CONFIG_HANNAH_MIC_I2S_PORT=0
CONFIG_HANNAH_MIC_BCK_GPIO=4
CONFIG_HANNAH_MIC_WS_GPIO=5
CONFIG_HANNAH_MIC_DATA_GPIO=6

# Speaker (MAX98357A)
CONFIG_HANNAH_SPK_BCK_GPIO=15
CONFIG_HANNAH_SPK_WS_GPIO=16
CONFIG_HANNAH_SPK_DATA_GPIO=7

# LED — onboard single WS2812B (DevKitC-1: GPIO48)
CONFIG_HANNAH_LED_GPIO=48
CONFIG_HANNAH_LED_COUNT=1

# Tasten — GPIO0 = BOOT-Taster auf dem DevKit als PTT
CONFIG_HANNAH_PTT_GPIO=0
CONFIG_HANNAH_MUTE_GPIO=11

# Kein Hardware-Mute-Transistor auf dem Breadboard — beliebiger freier GPIO
CONFIG_HANNAH_MUTE_HW_GPIO=2

# Sensoren — BMP280 + AHT20
CONFIG_HANNAH_SENSOR_TYPE_BMP280_AHT20=y
CONFIG_HANNAH_SENSOR_SDA_GPIO=8
CONFIG_HANNAH_SENSOR_SCL_GPIO=9
CONFIG_HANNAH_SENSOR_BMP280_ADDR=119

# OTA — kürzeres Intervall + Dev-Channel zum Testen
CONFIG_HANNAH_OTA_POLL_INTERVAL_S=300
CONFIG_HANNAH_OTA_CHANNEL="satellite-esp-dev"
